  - name: Scene 1B
    charactersData: []
    propsData: []
    nameString: Hikaru
    chatString: "Classes were exhausting today.\nOne lecture after another, \nendless
      notes, endless talking...\nI thought the day would never end."
    cutscenePreEvent:
