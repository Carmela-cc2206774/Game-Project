  - name: Scene 1C
    charactersData: []
    propsData: []
    nameString: Hikaru
    chatString: 'This was my favorite part of the day,

      walking home with no
      deadlines chasing me,

      no group projects, no professors, no pressure.'
    cutscenePreEvent:
      m_PersistentCalls:
        m_Calls:
